# Copy this file to .env and fill in the real values. .env is gitignored.

# Bot token from https://discord.com/developers/applications -> your app -> Bot
DISCORD_BOT_TOKEN=

# Server (guild) ID the bot commands should sync to instantly for testing.
# Leave empty to register commands globally (can take up to an hour to propagate).
DISCORD_GUILD_ID=

# Base URL of the MTGOCubeBot backend API.
BACKEND_API_URL=http://localhost:8000

# Name of the Discord category (channel section) session channels get
# created in. Must already exist on the server.
DISCORD_CATEGORY_NAME=Automated Draft on MTGO

# How often (in minutes) the bot checks for finished sessions and deletes
# their channel.
CLEANUP_INTERVAL_MINUTES=2
